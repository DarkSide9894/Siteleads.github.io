rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /test/connection {
      allow read: if true;
    }
    match /{document=**} {
      allow read, write: if false;
    }

    // 3. Global Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // 2. Validation Blueprints
    function isValidLead(data) {
      return data.keys().hasAll(['name', 'address', 'userId', 'createdAt', 'updatedAt', 'status'])
        && data.name is string && data.name.size() <= 200
        && data.address is string && data.address.size() <= 500
        && data.userId == request.auth.uid
        && data.status in ['discovered', 'proposal_generated', 'contacted', 'ignored']
        && data.createdAt == request.time
        && data.updatedAt == request.time;
    }

    match /leads/{leadId} {
      allow get: if isOwner(existing().userId) && isValidId(leadId);
      allow list: if isOwner(resource.data.userId);

      allow create: if isSignedIn() && isValidId(leadId) && isValidLead(incoming());

      allow update: if isOwner(existing().userId) && (
        // Action: Generate Proposal
        (incoming().diff(existing()).affectedKeys().hasOnly(['generatedProposal', 'status', 'updatedAt'])
         && incoming().status == 'proposal_generated'
         && incoming().updatedAt == request.time) ||
        // Action: Mark Contacted
        (incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt', 'emailAddress'])
         && incoming().status == 'contacted'
         && incoming().updatedAt == request.time) ||
        // Action: Ignore
        (incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt'])
         && incoming().status == 'ignored'
         && incoming().updatedAt == request.time)
      );

      allow delete: if isOwner(existing().userId);
    }
  }
}
